{
  "private": true,
  "scripts": {
    "clean": "node ./scripts/clean",
    "build": "node ./scripts/build",
    "dev": "node ./scripts/build --watch",
    "lint:eslint": "eslint --max-warnings=0 '**/*.{js,jsx,ts,tsx,cjs,mjs,yml,yaml}'",
    "lint:stylelint": "stylelint --quiet-deprecation-warnings --mw=0 '**/*.{css,scss}'",
    "lint": "run-p \"lint:* {@}\" --",
    "check-dependencies": "node ./scripts/check-dependencies",
    "prepare": "husky",
    "pre-commit": "lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx}": "eslint --max-warnings=0",
    "*.scss": "stylelint --mw=0"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "ansi-colors": "^4.1.3",
    "cpx": "^1.5.0",
    "dayjs": "^1.11.20",
    "depcheck": "^1.4.7",
    "esbuild": "^0.24.2",
    "eslint": "^9.39.4",
    "eslint-config-vshift": "^2.0.6",
    "fs-extra": "^11.3.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "lodash": "^4.18.1",
    "loglevel": "^1.9.2",
    "npm-run-all": "^4.1.5",
    "stylelint": "^16.26.1",
    "stylelint-config-vshift": "^1.2.0",
    "yaml": "^2.8.3",
    "yargs": "^17.7.2"
  }
}
